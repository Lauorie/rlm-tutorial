# 复制为 .env 并填入真实值（.env 已被 .gitignore 忽略，不会提交）。
# 注意：跑通教程的全部核心内容【不需要】任何 key —— 内置 MockLM 零成本。
# 仅当你想用真实大模型（demo --real / 在线 Demo use_real=true）时才需要下面这些。

# OpenAI 兼容接口的 key；base_url 可指向官方、国内代理或本地 vLLM 等任意兼容端点
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# 在线 Demo / demo --real 使用的模型名（可选，默认 gpt-4o-mini）
RLM_MODEL=gpt-4o-mini
